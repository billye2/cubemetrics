# Supabase (get these from your Supabase project dashboard or `vercel env pull`)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (for OAuth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feedback → GitHub workflow
# Token with issues:write (push) access on the repo below. Used server-side
# only when an admin approves feedback.
GITHUB_TOKEN=your-github-token-here
# owner/repo that approved feedback opens issues in (defaults to billye2/xpbbs)
GITHUB_REPO=billye2/xpbbs
# Account allowed to review/approve feedback (defaults to the project owner)
ADMIN_EMAIL=admin@example.com

# Remote DB migrations are applied via the Supabase MCP (apply_migration), not via
# env-stored DB credentials — so there is nothing to put here. Project ref is
# aennreackkegaqwwbowg (purrfect-bbs, us-east-1); authorize the MCP once per machine.

# ─────────────────────────────────────────────────────────────────────────────
# Proactive engine (Phase 4) — the digest emails stay DORMANT until these are set.
# Code ships safe-without-secrets: no key ⇒ the cron sends nothing.
# ─────────────────────────────────────────────────────────────────────────────
# Bearer secret the cron route checks (constant-time). Also set it in the cron
# trigger (Vercel Cron sets it automatically; pg_cron must send the header).
CRON_SECRET=
# Resend (email). Verify cubemetrics.com in Resend + add SPF/DKIM DNS on NameSilo.
RESEND_API_KEY=
NOTIFY_FROM=XP Boost <hello@cubemetrics.com>
# HMAC secret for one-click unsubscribe tokens.
NOTIFY_SIGNING_SECRET=
# To activate scheduling: add a cron hitting /api/cron/digest every ~30 min
# (Vercel Pro `*/30 * * * *`, or Supabase pg_cron). Keep the select.ts window
# >= the cron interval so no send window is missed.

# AI insight line (Phase 5). The Today insight ships deterministic (no AI) today.
# To upgrade to AI-written lines: `npm i ai zod`, set both below, and wire the
# model at src/lib/ai/nudge-input.ts::getNudge (see docs/app-plans/spine-phase5.md).
AI_NUDGES_ENABLED=
AI_GATEWAY_API_KEY=
